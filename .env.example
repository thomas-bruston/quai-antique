# ================================================
# LE QUAI ANTIQUE — Variables d'environnement
# Copier ce fichier en .env et remplir les valeurs
# NE JAMAIS COMMITTER LE FICHIER .env
# ================================================

APP_ENV=development
APP_URL=http://localhost:8080

# ---- MySQL ----
MYSQL_ROOT_PASSWORD=rootpassword
MYSQL_DATABASE=quai_antique
MYSQL_USER=app_user
MYSQL_PASSWORD=app_user_password
MYSQL_HOST=mysql
MYSQL_PORT=3306

# ---- MongoDB ----
MONGO_ROOT_USER=root
MONGO_ROOT_PASSWORD=rootpassword
MONGO_DATABASE=quai_antique_contact
MONGO_HOST=mongo
MONGO_PORT=27017

# ---- Sécurité ----
# Clé pour les tokens CSRF (32 caractères aléatoires)
APP_SECRET=changeme_generate_a_random_32_char_string
