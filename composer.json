{
    "name": "quai-antique/app",
    "description": "Application de reservation du restaurant quai-antique",
    "type": "project",
    "require": {
        "php": "^8.3",
        "mongodb/mongodb": "^2.0"
    },
    "require-dev": {
        "phpunit/phpunit": "^11.0"
    },
    "autoload": {
        "psr-4": {
            "Core\\":       "src/Core/",
            "Controller\\": "src/Controller/",
            "Service\\":    "src/Service/",
            "Repository\\": "src/Repository/",
            "Entity\\":     "src/Entity/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests/"
        }
    },
    "config": {
        "optimize-autoloader": true
    }
}